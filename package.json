{
  "name": "tamias",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*",
    "dashboard",
    "api",
    "worker"
  ],
  "scripts": {
    "build": "bun run --workspaces --if-present build",
    "check:architecture": "bun run scripts/check-architecture.ts",
    "ci:affected": "bun run scripts/ci-affected.ts",
    "clean": "git clean -xdf node_modules",
    "clean:workspaces": "bun run --workspaces --if-present clean",
    "dev": "bun run --filter '@tamias/dashboard' --filter '@tamias/api' --filter '@tamias/worker' --parallel --if-present dev",
    "dev:fresh": "bash scripts/kill-dev-ports.sh && bun run dev",
    "dev:local": "bun run dev:dashboard",
    "deploy:cloudflare:dashboard:production": "cd dashboard && bun run build:start && wrangler deploy --config ../wrangler.jsonc --env=production",
    "deploy:cloudflare:dashboard:staging": "cd dashboard && bun run build:start && wrangler deploy --config ../wrangler.jsonc --env=staging",
    "preflight:cloudflare:dashboard": "cd dashboard && bun run preflight:cf",
    "preflight:cloudflare:dashboard:staging": "cd dashboard && bun run preflight:cf:staging",
    "preflight:cloudflare:dashboard:production": "cd dashboard && bun run preflight:cf:production",
    "preflight:cloudflare:staging": "bun run preflight:cloudflare:dashboard:staging",
    "preflight:cloudflare:production": "bun run preflight:cloudflare:dashboard:production",
    "preflight:cloudflare": "bun run preflight:cloudflare:dashboard",
    "test": "bun run --workspaces --parallel --if-present test",
    "test:e2e": "playwright test -c playwright.config.ts",
    "test:e2e:headed": "playwright test -c playwright.config.ts --headed",
    "start:dashboard": "bun run --filter @tamias/dashboard start",
    "dev:dashboard": "bun run --filter @tamias/dashboard dev",
    "build:dashboard": "bun run --filter @tamias/dashboard build",
    "backfill:derived-compliance-ledger": "bun --env-file=.env run scripts/backfill-derived-compliance-ledger.ts",
    "backfill:customer-tracker-search-texts": "bun --env-file=.env run scripts/backfill-customer-tracker-search-texts.ts",
    "backfill:document-tag-assignment-sort-fields": "bun --env-file=.env run scripts/backfill-document-tag-assignment-sort-fields.ts",
    "backfill:document-search-texts": "bun --env-file=.env run scripts/backfill-document-search-texts.ts",
    "backfill:invoice-report-aggregates": "bun --env-file=.env run scripts/backfill-invoice-report-aggregates.ts",
    "backfill:inbox-liability-aggregates": "bun --env-file=.env run scripts/backfill-inbox-liability-aggregates.ts",
    "backfill:inbox-status-aggregates": "bun --env-file=.env run scripts/backfill-inbox-status-aggregates.ts",
    "backfill:public-invoice-search-texts": "bun --env-file=.env run scripts/backfill-public-invoice-search-texts.ts",
    "backfill:transaction-attachment-flags": "bun --env-file=.env run scripts/backfill-transaction-attachment-flags.ts",
    "backfill:transaction-match-suggestion-learning-fields": "bun --env-file=.env run scripts/backfill-transaction-match-suggestion-learning-fields.ts",
    "backfill:tracker-project-tag-sort-fields": "bun --env-file=.env run scripts/backfill-tracker-project-tag-sort-fields.ts",
    "backfill:transaction-report-aggregates": "bun --env-file=.env run scripts/backfill-transaction-report-aggregates.ts",
    "backfill:transaction-tag-sort-fields": "bun --env-file=.env run scripts/backfill-transaction-tag-sort-fields.ts",
    "format": "prettier --write .",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "bun run --workspaces --parallel --if-present typecheck"
  },
  "packageManager": "bun@1.3.11",
  "catalog": {
    "@ai-sdk/anthropic": "3.0.64",
    "@ai-sdk/google": "^3.0.53",
    "@ai-sdk/mistral": "3.0.27",
    "@ai-sdk/openai": "3.0.48",
    "@ai-sdk/react": "3.0.143",
    "@ai-sdk/rsc": "2.0.141",
    "@date-fns/tz": "^1.4.1",
    "@fast-csv/format": "5.0.5",
    "@react-pdf/renderer": "^4.3.1",
    "@sindresorhus/slugify": "^3.0.0",
    "ai": "6.0.141",
    "camelcase-keys": "^10.0.1",
    "change-case": "^5.4.4",
    "date-fns": "^4.1.0",
    "hono": "4.12.9",
    "jose": "^6.1.3",
    "nanoid": "^5.1.6",
    "node-xlsx": "^0.24.0",
    "papaparse": "^5.5.3",
    "pino": "^10.1.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "resend": "^6.5.2",
    "sharp": "0.34.5",
    "typescript": "^6.0.2",
    "uuid": "^13.0.0",
    "zod": "^4.3.5"
  },
  "trustedDependencies": [
    "@depot/cli",
    "core-js",
    "protobufjs"
  ],
  "devDependencies": {
    "@eslint/js": "9",
    "@playwright/test": "^1.55.1",
    "eslint": "9",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "globals": "^17.4.0",
    "prettier": "^3.8.1",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.0"
  }
}
