{
  "extends": "@tamias/tsconfig/base.json",
  "compilerOptions": {
    "baseUrl": ".",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowArbitraryExtensions": true,
    "ignoreDeprecations": "6.0",
    "jsx": "preserve",
    "noEmit": true,
    "paths": {
      "@/*": ["./src/*"],
      "@convex/*": ["./convex/*"],
      "@app-data/*": ["../../packages/app-data/src/*"],
      "@convex-dev/auth/react": ["./src/framework/convex-auth-client.tsx"],
      "nuqs": ["./src/framework/nuqs/index.tsx"],
      "nuqs/server": ["./src/framework/nuqs/server.ts"],
      "nuqs/adapters/tanstack-router": ["./src/framework/nuqs/tanstack-router.tsx"]
    },
    "strict": true
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    "../../types",
    "vite.config.mts",
    "tailwind.config.ts"
  ],
  "exclude": ["node_modules"]
}
