{
  "name": "@tamias/dashboard",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build:cf": "opennextjs-cloudflare build",
    "build": "NODE_ENV=production next build --turbopack",
    "clean": "git clean -xdf .next .turbo node_modules",
    "convex:codegen": "convex codegen",
    "convex:dev": "convex dev",
    "dev": "TZ=UTC next dev -p 3001 --turbopack",
    "deploy:cf": "bun run build:cf && opennextjs-cloudflare deploy --config wrangler.jsonc",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "preview:cf": "bun run build:cf && opennextjs-cloudflare preview --config wrangler.jsonc",
    "preflight:cf": "bun run build:cf && wrangler deploy --dry-run --config wrangler.jsonc --env=\"\"",
    "preflight:cf:staging": "bun run build:cf && wrangler deploy --dry-run --config wrangler.jsonc --env=staging",
    "preflight:cf:production": "bun run build:cf && wrangler deploy --dry-run --config wrangler.jsonc --env=production",
    "start": "next start",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "typecheck": "tsc --noEmit",
    "test": "find src -name '*.test.ts' -o -name '*.spec.ts' | grep -q . && bun test --exit src || echo 'No tests yet'"
  },
