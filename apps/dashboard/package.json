{
  "name": "@tamias/dashboard",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build:cf": "bun run build:start",
    "build:start": "bun run routes:generate:start && bun run content:generate && vite build",
    "content:generate": "bun run scripts/generate-site-content-manifest.ts",
    "build": "bun run build:start",
    "clean": "git clean -xdf .tanstack .turbo dist node_modules",
    "convex:codegen": "convex codegen",
    "convex:dev": "convex dev",
    "dev": "bun run dev:start",
    "dev:start": "bun run routes:generate:start && bun run content:generate && TZ=UTC vite dev --host 0.0.0.0 --port 3001",
    "prebuild": "bun run content:generate",
    "predeploy": "bun run content:generate",
    "predev": "bun run content:generate",
    "prepreview": "bun run content:generate",
    "pretypecheck": "bun run content:generate",
    "deploy:cf": "bun run build:start && wrangler deploy --config wrangler.start.jsonc --env=production",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "preview:cf": "bun run build:start && wrangler dev --config wrangler.start.jsonc",
    "preflight:cf": "bun run build:start && wrangler deploy --dry-run --config wrangler.start.jsonc",
    "preflight:cf:staging": "bun run build:start && wrangler deploy --dry-run --config wrangler.start.jsonc --env=staging",
    "preflight:cf:production": "bun run build:start && wrangler deploy --dry-run --config wrangler.start.jsonc --env=production",
    "preflight:cf:start": "bun run build:start && wrangler deploy --dry-run --config wrangler.start.jsonc",
    "preflight:cf:start:staging": "bun run build:start && wrangler deploy --dry-run --config wrangler.start.jsonc --env=staging",
    "preflight:cf:start:production": "bun run build:start && wrangler deploy --dry-run --config wrangler.start.jsonc --env=production",
    "preview:start": "bun run routes:generate:start && bun run content:generate && vite preview --host 0.0.0.0 --port 3001",
    "routes:generate:start": "bun run scripts/generate-start-route-tree.ts",
    "start": "bun run preview:start",
    "test:e2e": "playwright test -c playwright.config.ts",
    "test:e2e:headed": "playwright test -c playwright.config.ts --headed",
    "typecheck:start": "bun run routes:generate:start && bun run content:generate && tsc --noEmit -p tsconfig.start.json",
    "typecheck": "tsc --noEmit",
    "test": "find src -name '*.test.ts' -o -name '*.spec.ts' | grep -q . && bun test --exit src || echo 'No tests yet'"
  },
  "dependencies": {
    "@ai-sdk-tools/artifacts": "^1.2.0",
