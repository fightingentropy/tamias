# Convex Auth
CONVEX_URL=https://fleet-chameleon-251.eu-west-1.convex.cloud
CONVEX_SITE_URL=https://fleet-chameleon-251.eu-west-1.convex.site
# Optional: same value as apps/api `INTERNAL_API_KEY` when using trusted session headers in SSR
INTERNAL_API_KEY=
# Local API: put CONVEX_SERVICE_KEY in apps/api/.dev.vars (Wrangler), or SSO/login will loop back to /login

# Shared app URLs (local: use repo-root `bun run dev` so API is on 3003)
DASHBOARD_URL=http://localhost:3001
WEBSITE_URL=http://localhost:3000
API_URL=http://localhost:3003

# Resend
RESEND_API_KEY=
RESEND_AUDIENCE_ID=


# Teller
# mTLS client auth uses the Cloudflare Worker binding TELLER_MTLS_CERTIFICATE
# in API/worker runtimes. The dashboard only needs the public Teller client vars.
TELLER_APPLICATION_ID=
TELLER_ENVIRONMENT=
TELLER_SIGNING_SECRET=

# Plaid
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENVIRONMENT=

# Plain
PLAIN_API_KEY=

# OpenAI
OPENAI_API_KEY=

# OpenPanel
OPENPANEL_CLIENT_ID=
OPENPANEL_SECRET_KEY=

# Webhook
WEBHOOK_SECRET_KEY=6c369443-1a88-444e-b459-7e662c1fff9e



# Azure
AZURE_DOCUMENT_INTELLIGENCE_ENDPOINT=
AZURE_DOCUMENT_INTELLIGENCE_KEY=

# Google Maps
GOOGLE_API_KEY=

# Invoice
INVOICE_JWT_SECRET=secret

# Midday Cache
MIDDAY_CACHE_API_SECRET=

# Polar
POLAR_ACCESS_TOKEN=
POLAR_ENVIRONMENT=sandbox
POLAR_WEBHOOK_SECRET=

# File Key Secret
FILE_KEY_SECRET=secret

# Gmail
GMAIL_CLIENT_ID=<your-client-id>
GMAIL_CLIENT_SECRET=<your-client-secret>
GMAIL_REDIRECT_URI=http://localhost:3003/apps/gmail/oauth-callback

# Outlook
OUTLOOK_CLIENT_ID=<your-client-id>
OUTLOOK_CLIENT_SECRET=<your-client-secret>
OUTLOOK_REDIRECT_URI=http://localhost:3003/apps/outlook/oauth-callback

# Stripe
STRIPE_PUBLISHABLE_KEY=your_publishable_key_here
