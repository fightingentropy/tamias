{
  "name": "@tamias/worker",
  "version": "0.0.1",
  "private": true,
  "exports": {
    "./cloudflare": "./src/cloudflare/index.ts"
  },
  "scripts": {
    "cf-typegen": "tmpdir=$(mktemp -d) && wrangler types \"$PWD/src/cloudflare-env.d.ts\" --config \"$PWD/wrangler.jsonc\" --cwd \"$tmpdir\" --env-file \"$PWD/.env-template\" && rm -rf \"$tmpdir\"",
    "dev": "wrangler dev",
    "deploy:cf:bridge": "wrangler deploy --config wrangler.jsonc",
    "deploy:cf:capture": "wrangler deploy --config wrangler.capture.jsonc",
    "deploy:cf:ledger": "wrangler deploy --config wrangler.ledger.jsonc",
    "preflight:cf:bridge": "wrangler deploy --dry-run --config wrangler.jsonc --env=\"\"",
    "preflight:cf:bridge:staging": "wrangler deploy --dry-run --config wrangler.jsonc --env=staging",
    "preflight:cf:bridge:production": "wrangler deploy --dry-run --config wrangler.jsonc --env=production",
    "preflight:cf:capture": "wrangler deploy --dry-run --config wrangler.capture.jsonc --env=\"\"",
    "preflight:cf:capture:staging": "wrangler deploy --dry-run --config wrangler.capture.jsonc --env=staging",
    "preflight:cf:capture:production": "wrangler deploy --dry-run --config wrangler.capture.jsonc --env=production",
    "preflight:cf:ledger": "wrangler deploy --dry-run --config wrangler.ledger.jsonc --env=\"\"",
    "preflight:cf:ledger:staging": "wrangler deploy --dry-run --config wrangler.ledger.jsonc --env=staging",
    "preflight:cf:ledger:production": "wrangler deploy --dry-run --config wrangler.ledger.jsonc --env=production",
    "test": "bun test --exit src",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "generate-insight": "bun run scripts/generate-test-insight.ts"
  },
  "dependencies": {
    "@ai-sdk/google": "catalog:",
    "@ai-sdk/openai": "catalog:",
    "@fast-csv/format": "catalog:",
    "@tamias/accounting": "workspace:*",
    "@tamias/app-store": "workspace:*",
    "@tamias/banking": "workspace:*",
    "@tamias/app-data": "workspace:*",
    "@tamias/documents": "workspace:*",
    "@tamias/email": "workspace:*",
    "@tamias/import": "workspace:*",
    "@tamias/inbox": "workspace:*",
    "@tamias/insights": "workspace:*",
    "@tamias/invoice": "workspace:*",
    "@tamias/job-client": "workspace:*",
    "@tamias/logger": "workspace:*",
    "@tamias/notifications": "workspace:*",
    "@tamias/storage": "workspace:*",
    "@tamias/trpc": "workspace:*",
    "@tamias/utils": "workspace:*",
    "@types/archiver": "^7.0.0",
    "ai": "catalog:",
    "archiver": "^7.0.1",
    "camelcase-keys": "^10.0.2",
    "date-fns": "catalog:",
    "exa-js": "^2.0.12",
    "hono": "catalog:",
    "node-xlsx": "catalog:",
    "papaparse": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/papaparse": "^5.5.2",
    "@types/react": "^19.2.13",
    "wrangler": "^4.43.0"
  }
}
