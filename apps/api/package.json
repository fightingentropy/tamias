{
  "name": "@tamias/api",
  "scripts": {
    "prompts:generate": "bun run scripts/generate-agent-prompts.ts",
    "dev": "wrangler dev --port 3003 --env-file .env",
    "dev:cf": "wrangler dev",
    "deploy:cf": "wrangler deploy",
    "preflight:cf": "wrangler deploy --dry-run --env=\"\"",
    "preflight:cf:staging": "wrangler deploy --dry-run --env=staging",
    "preflight:cf:production": "wrangler deploy --dry-run --env=production",
    "cf-typegen": "tmpdir=$(mktemp -d) && wrangler types \"$PWD/src/cloudflare-env.d.ts\" --config \"$PWD/wrangler.jsonc\" --cwd \"$tmpdir\" --env-file \"$PWD/.env-template\" && rm -rf \"$tmpdir\"",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "predeploy:cf": "bun run prompts:generate",
    "predev": "bun run prompts:generate",
    "predev:cf": "bun run prompts:generate",
    "pretypecheck": "bun run prompts:generate",
    "typecheck": "tsc --noEmit",
    "test": "find src -name '*.test.ts' -o -name '*.spec.ts' | grep -q . && bun test --exit src || echo 'No tests yet'"
  },
  "exports": {
    ".": "./src/index.ts",
    "./trpc/routers/_app": "./src/trpc/routers/_app.ts"
  },
  "dependencies": {
    "@ai-sdk-tools/agents": "^1.2.0",
    "@ai-sdk-tools/artifacts": "^1.2.0",
    "@ai-sdk/anthropic": "catalog:",
    "@ai-sdk/openai": "catalog:",
    "@date-fns/tz": "catalog:",
    "@hono/mcp": "^0.2.5",
    "@hono/trpc-server": "^0.4.2",
    "@hono/zod-openapi": "1.2.4",
    "@tamias/accounting": "workspace:*",
    "@tamias/contracts": "workspace:*",
    "@tamias/ai-artifacts": "workspace:*",
    "@tamias/app-data": "workspace:*",
    "@tamias/app-services": "workspace:*",
    "@tamias/app-store": "workspace:*",
    "@tamias/auth-session": "workspace:*",
    "@tamias/banking": "workspace:*",
    "@tamias/cache": "workspace:*",
    "@tamias/categories": "workspace:*",
    "@tamias/compliance": "workspace:*",
    "@tamias/domain": "workspace:*",
    "@tamias/documents": "workspace:*",
    "@tamias/email": "workspace:*",
    "@tamias/encryption": "workspace:*",
    "@tamias/import": "workspace:*",
    "@tamias/inbox": "workspace:*",
    "@tamias/insights": "workspace:*",
    "@tamias/invoice": "workspace:*",
    "@tamias/job-client": "workspace:*",
    "@tamias/worker": "workspace:*",
    "@tamias/location": "workspace:*",
    "@tamias/logger": "workspace:*",
    "@tamias/notifications": "workspace:*",
    "@tamias/plans": "workspace:*",
    "@tamias/storage": "workspace:*",
    "@tamias/utils": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@polar-sh/sdk": "^0.46.7",
    "@scalar/hono-api-reference": "^0.10.5",
    "@sindresorhus/slugify": "catalog:",
    "@team-plain/typescript-sdk": "^5.12.1",
    "@trpc/server": "^11.16.0",
    "ai": "catalog:",
    "date-fns": "catalog:",
    "hono": "catalog:",
    "jose": "catalog:",
    "nanoid": "catalog:",
    "parse-duration": "^2.1.4",
    "resend": "catalog:",
    "stripe": "^21.0.1",
    "superjson": "^2.2.6",
    "uuid": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "wrangler": "^4.43.0"
  }
}
