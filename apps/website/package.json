{
  "name": "@tamias/website",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build:cf": "opennextjs-cloudflare build",
    "content:generate": "bun run scripts/generate-content-manifest.ts",
    "build": "NODE_ENV=production next build --turbopack",
    "clean": "git clean -xdf .next .turbo node_modules",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts",
    "prebuild": "bun run content:generate",
    "predeploy": "bun run content:generate",
    "predev": "bun run content:generate",
    "prepreview": "bun run content:generate",
    "dev": "TZ=UTC next dev --turbopack -p 3000",
    "deploy:cf": "bun run build:cf && opennextjs-cloudflare deploy --config wrangler.jsonc",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "preview:cf": "bun run build:cf && opennextjs-cloudflare preview --config wrangler.jsonc",
    "preflight:cf": "bun run build:cf && wrangler deploy --dry-run --config wrangler.jsonc --env=\"\"",
    "preflight:cf:staging": "bun run build:cf && wrangler deploy --dry-run --config wrangler.jsonc --env=staging",
    "preflight:cf:production": "bun run build:cf && wrangler deploy --dry-run --config wrangler.jsonc --env=production",
    "typecheck": "tsc --noEmit",
    "start": "next start"
  },
  "dependencies": {
    "@ai-sdk/openai": "catalog:",
    "@ai-sdk/react": "catalog:",
    "@opennextjs/cloudflare": "^1.8.3",
    "@tamias/app-store": "workspace:*",
    "@tamias/events": "workspace:*",
    "@tamias/ui": "workspace:*",
    "@tamias/utils": "workspace:*",
    "@openpanel/nextjs": "^1.1.3",
    "@openstatus/react": "^0.0.3",
    "ai": "catalog:",
    "hls.js": "^1.6.15",
    "motion": "^12.34.0",
    "next": "16.1.6",
    "next-mdx-remote": "^6.0.0",
    "nuqs": "^2.8.8",
    "react": "catalog:",
    "react-dom": "catalog:",
    "remark-gfm": "^4.0.1",
    "streamdown": "1.2.0",
    "sugar-high": "^0.9.5"
  },
  "devDependencies": {
    "@tamias/tsconfig": "workspace:*",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.13",
    "wrangler": "^4.43.0"
  }
}
