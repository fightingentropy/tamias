{
  "name": "@tamias/dashboard",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build:start": "bun run routes:generate:start && vite build",
    "build": "bun run build:start",
    "clean": "git clean -xdf .tanstack dist node_modules",
    "convex:codegen": "convex codegen",
    "convex:dev": "bun --env-file=../.env --cwd . x convex dev",
    "dev": "bun run dev:start",
    "dev:start": "bun run routes:generate:start && TZ=UTC vite dev --host 0.0.0.0 --port 3001",
    "preview:cf": "bun run build:start && bun --env-file=../.env x wrangler dev --config ../wrangler.jsonc",
    "preflight:cf": "bun run build:start && wrangler deploy --dry-run --config ../wrangler.jsonc",
    "preflight:cf:staging": "bun run build:start && wrangler deploy --dry-run --config ../wrangler.jsonc --env=staging",
    "preflight:cf:production": "bun run build:start && wrangler deploy --dry-run --config ../wrangler.jsonc --env=production",
    "preview:start": "bun run routes:generate:start && vite preview --host 0.0.0.0 --port 3001",
    "routes:generate:start": "bun run scripts/generate-start-route-tree.ts",
    "start": "bun run preview:start",
    "typecheck": "tsc --noEmit",
    "test": "bun test --exit src"
  },
