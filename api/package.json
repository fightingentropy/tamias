    "prompts:generate": "bun run scripts/generate-agent-prompts.ts",
    "predev": "bun run prompts:generate",
    "pretypecheck": "bun run prompts:generate",
    "typecheck": "tsc --noEmit",
    "test": "find src -name '*.test.ts' -o -name '*.spec.ts' | grep -q . && bun test --preload ./src/__tests__/setup.ts --exit src || echo 'No tests yet'"
